---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('perspektiven', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('de-CH', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
};
---

<BaseLayout title={post.data.title} description={post.data.description} article={{ title: post.data.title, description: post.data.description, date: post.data.date, image: post.data.image, slug: post.id }}>
  <article class="evans-page">
    <div class="container">

      <hr class="section-divider" />
      <div class="evans-section">
        <div class="evans-label">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-author">Jochen Witte</span>
        </div>
        <div class="evans-content">
          <h1 class="post-title">{post.data.title}</h1>
          <div class="post-body">
            <Content />
          </div>
          <footer>
            <a href="/perspektiven/" class="back-link">&larr; Alle Perspektiven</a>
          </footer>
        </div>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .section-divider {
    border: none;
    border-top: 1px solid var(--color-coral);
    margin: var(--space-xl) 0 0 0;
  }

  .evans-section {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 0;
    margin-top: var(--space-xl);
  }

  .evans-label {
    padding: 0 var(--space-lg) var(--space-xl) 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-coral);
    letter-spacing: 0.5px;
    display: block;
    position: sticky;
    top: 80px;
  }

  .post-author {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-light);
    display: block;
    margin-top: var(--space-xs);
    position: sticky;
    top: 96px;
  }

  .evans-content {
    border-left: 1px solid var(--color-coral);
    padding: 0 0 var(--space-xl) var(--space-lg);
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: 36px;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-lg) 0;
    line-height: 1.2;
    max-width: 720px;
  }

  .post-body {
    max-width: var(--content-width);
  }

  .post-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 600;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .post-body :global(p) {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    margin: var(--space-lg) 0;
  }

  .post-body :global(ul), .post-body :global(ol) {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.7;
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .post-body :global(strong) {
    font-weight: 600;
  }

  .post-body :global(a) {
    color: var(--color-coral);
    text-decoration: none;
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(.cta) {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-coral);
    border: 1px solid var(--color-coral);
    padding: 0.6em 1.4em;
    letter-spacing: 0.3px;
    margin-top: var(--space-md);
    text-decoration: none;
  }

  .post-body :global(.cta:hover) {
    background: var(--color-coral);
    color: var(--color-white);
    text-decoration: none;
  }

  footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-coral);
    margin-bottom: var(--space-xl);
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-coral);
  }

  .back-link:hover {
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .evans-section {
      grid-template-columns: 1fr;
    }

    .evans-label {
      padding: var(--space-lg) 0 0 0;
      display: flex;
      gap: var(--space-md);
    }

    .post-date, .post-author {
      position: static;
    }

    .evans-content {
      border-left: none;
      border-top: 1px solid var(--color-coral);
      padding: var(--space-md) 0 var(--space-lg) 0;
    }

    .post-title {
      font-size: 28px;
    }
  }
</style>
