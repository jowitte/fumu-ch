---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'perspektiven');
const posts = (await getCollection('perspektiven', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="container content">
    <h1>{page.data.title}</h1>
    <p>{page.data.description}</p>

    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <a href={`/perspektiven/${post.id}/`}>
              <h2>{post.data.title}</h2>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('de-CH', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              {post.data.category && <span class="category">{post.data.category}</span>}
              <p>{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p>Neue Perspektiven erscheinen in Kürze.</p>
    )}
  </section>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    margin-top: var(--space-lg);
  }
  .post-item {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-neutral);
  }
  .post-item a {
    color: inherit;
  }
  .post-item a:hover { text-decoration: none; }
  .post-item a:hover h2 { color: var(--color-accent); }
  .post-item h2 {
    margin-top: 0;
    margin-bottom: var(--space-xs);
  }
  time {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }
  .category {
    font-size: 0.8rem;
    background: var(--color-neutral);
    padding: 2px 8px;
    border-radius: 3px;
    margin-left: var(--space-sm);
  }
</style>
