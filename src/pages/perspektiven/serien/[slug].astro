---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { series as seriesRegistry } from '../../../data/series';

export async function getStaticPaths() {
  return Object.entries(seriesRegistry).map(([slug, data]) => ({
    params: { slug },
    props: { slug, seriesData: data },
  }));
}

const { slug, seriesData } = Astro.props;

const parts = (await getCollection('perspektiven', ({ data }) => !data.draft && data.series === slug))
  .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));

const formatDate = (date: Date) => {
  return date.toLocaleDateString('de-CH', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
};
---

<BaseLayout title={seriesData.name} description={seriesData.teaser}>

  <section class="evans-page">
    <div class="container">

      <h1>{seriesData.name}</h1>

      <p class="intro">{seriesData.teaser}</p>

      <hr class="section-divider" />
      <div class="evans-section">
        <div class="evans-label">
          <h2>Teile</h2>
        </div>
        <div class="evans-content">
          {parts.map(post => (
            <a href={`/perspektiven/${post.id}/`} class="post-item">
              <span class="part-no">Teil {post.data.seriesPart}</span>
              <div class="post-body">
                <h3 class="post-title">{post.data.title}</h3>
                <span class="post-date">{formatDate(post.data.date)}</span>
                <p class="post-excerpt">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <footer>
        <a href="/perspektiven/" class="back-link">&larr; Alle Perspektiven</a>
      </footer>

    </div>
  </section>

</BaseLayout>

<style>
  .intro {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 720px;
    margin: 0 0 var(--space-xl) 0;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-coral);
    margin: var(--space-xl) 0 0 0;
  }

  .evans-section {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 0;
    margin: var(--space-xl) 0;
  }

  .evans-label {
    padding: 0 var(--space-lg) 0 0;
    display: flex;
    justify-content: flex-end;
  }

  .evans-label h2 {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-coral);
    margin: 0;
    position: sticky;
    top: 80px;
  }

  .evans-content {
    border-left: 1px solid var(--color-coral);
    padding: 0;
  }

  .post-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-md);
    padding: var(--space-lg) 0 var(--space-lg) var(--space-lg);
    color: inherit;
    text-decoration: none;
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-item + .post-item {
    border-top: 1px solid var(--color-neutral);
  }

  .post-item:hover .post-title {
    color: var(--color-coral);
  }

  .post-item:hover {
    text-decoration: none;
  }

  .part-no {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-coral);
    letter-spacing: 0.5px;
    padding-top: 4px;
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-xs) 0;
    transition: color 0.15s;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .post-excerpt {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
    max-width: 600px;
  }

  footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-coral);
    margin-bottom: var(--space-xl);
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-coral);
  }

  .back-link:hover {
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .intro {
      font-size: 18px;
      margin: 0 0 var(--space-lg) 0;
    }

    .evans-section {
      grid-template-columns: 1fr;
    }

    .evans-label {
      padding: var(--space-lg) 0 0 0;
    }

    .evans-label h2 {
      position: static;
    }

    .evans-content {
      border-left: none;
      border-top: 1px solid var(--color-coral);
      padding: var(--space-md) 0 0 0;
    }

    .post-item {
      grid-template-columns: 1fr;
      padding-left: 0;
    }
  }
</style>
