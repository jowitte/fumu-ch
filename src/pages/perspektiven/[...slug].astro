---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveAuthors, getAuthorUrl } from '../../content/authors';
import { getSeries } from '../../data/series';

export async function getStaticPaths() {
  const posts = await getCollection('perspektiven', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('de-CH', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
};

const postAuthors = resolveAuthors(post.data.authors);

// Serien-Kontext: Hinweis oben + Vor/Zurück-Navigation am Ende.
const seriesSlug = post.data.series;
const seriesData = getSeries(seriesSlug);
let prevPost: typeof post | null = null;
let nextPost: typeof post | null = null;
if (seriesSlug && seriesData) {
  const seriesParts = (await getCollection('perspektiven', ({ data }) => !data.draft && data.series === seriesSlug))
    .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
  const idx = seriesParts.findIndex(p => p.id === post.id);
  prevPost = idx > 0 ? seriesParts[idx - 1] : null;
  nextPost = idx >= 0 && idx < seriesParts.length - 1 ? seriesParts[idx + 1] : null;
}
---

<BaseLayout title={post.data.title} description={post.data.description} article={{ title: post.data.title, description: post.data.description, date: post.data.date, image: post.data.image, slug: post.id, authors: postAuthors }}>
  <article class="evans-page">
    <div class="container">

      <div class="evans-section">
        <div class="evans-label">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-author">
            {postAuthors.map((author, i) => (
              <>
                {i > 0 && (i === postAuthors.length - 1 ? ' und ' : ', ')}
                <a href={getAuthorUrl(author.slug)}>{author.name}</a>
              </>
            ))}
          </span>
        </div>
        <div class="evans-content">
          {seriesData && seriesSlug && (
            <a href={`/perspektiven/serien/${seriesSlug}/`} class="series-hint">
              Teil {post.data.seriesPart} der Serie <strong>{seriesData.name}</strong>
            </a>
          )}
          <h1 class="post-title">{post.data.title}</h1>
          <div class="post-body">
            <Content />
          </div>
          <aside class="post-newsletter">
            <p class="post-newsletter-text">Perspektiven wie diese – gelegentlich per E-Mail.</p>
            <a href="/kontakt/#newsletter" class="post-newsletter-link">Newsletter abonnieren &rarr;</a>
          </aside>
          <footer>
            {seriesData && (prevPost || nextPost) && (
              <nav class="series-nav" aria-label={`Navigation innerhalb der Serie ${seriesData.name}`}>
                {prevPost ? (
                  <a href={`/perspektiven/${prevPost.id}/`} class="series-nav-link series-nav-prev">
                    <span class="series-nav-dir">&larr; Vorheriger Teil</span>
                    <span class="series-nav-title">{prevPost.data.title}</span>
                  </a>
                ) : <span class="series-nav-spacer"></span>}
                {nextPost ? (
                  <a href={`/perspektiven/${nextPost.id}/`} class="series-nav-link series-nav-next">
                    <span class="series-nav-dir">Nächster Teil &rarr;</span>
                    <span class="series-nav-title">{nextPost.data.title}</span>
                  </a>
                ) : <span class="series-nav-spacer"></span>}
              </nav>
            )}
            <a href="/perspektiven/" class="back-link">&larr; Alle Perspektiven</a>
          </footer>
        </div>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .evans-section {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 0;
    margin: var(--space-xl) 0;
  }

  .evans-label {
    padding: 0 var(--space-lg) 0 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
    letter-spacing: 0.5px;
    display: block;
    position: sticky;
    top: 80px;
  }

  .post-author {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-light);
    display: block;
    margin-top: var(--space-xs);
    position: sticky;
    top: 96px;
  }

  .post-author a {
    color: inherit;
    text-decoration: none;
  }

  .post-author a:hover {
    color: var(--color-coral);
  }

  .evans-content {
    border-left: 1px solid var(--color-coral);
    padding: 0 0 0 var(--space-lg);
  }

  /* fumu CI (2026-07-15): Serifen nur in H1, Coral durchgehend für Überschriften */
  .post-title {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 600;
    color: var(--color-coral);
    margin: 0 0 var(--space-lg) 0;
    line-height: 1.2;
    max-width: 720px;
  }

  .post-body {
    max-width: var(--content-width);
  }

  .post-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 500;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .post-body :global(p) {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    margin: var(--space-lg) 0;
  }

  .post-body :global(ul), .post-body :global(ol) {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .post-body :global(strong) {
    font-weight: 600;
  }

  .post-body :global(a) {
    color: var(--color-coral);
    text-decoration: none;
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(.cta) {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-coral);
    border: 1px solid var(--color-coral);
    padding: 0.6em 1.4em;
    letter-spacing: 0.3px;
    margin-top: var(--space-md);
    text-decoration: none;
  }

  .post-body :global(.cta:hover) {
    background: var(--color-coral);
    color: var(--color-white);
    text-decoration: none;
  }

  .series-hint {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-light);
    letter-spacing: 0.3px;
    text-decoration: none;
    display: inline-block;
    margin-bottom: var(--space-sm);
  }

  .series-hint strong {
    font-weight: 600;
    color: var(--color-coral);
  }

  .series-hint:hover strong {
    text-decoration: underline;
  }

  .series-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .series-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    color: inherit;
  }

  .series-nav-next {
    text-align: right;
  }

  .series-nav-dir {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-coral);
    letter-spacing: 0.5px;
  }

  .series-nav-title {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
  }

  .series-nav-link:hover .series-nav-title {
    color: var(--color-coral);
  }

  .post-newsletter {
    max-width: var(--content-width);
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-neutral);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .post-newsletter-text {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-text);
    margin: 0;
  }

  .post-newsletter-link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: var(--color-coral);
    white-space: nowrap;
  }

  .post-newsletter-link:hover {
    text-decoration: underline;
  }

  footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-coral);
    margin-bottom: var(--space-xl);
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-coral);
  }

  .back-link:hover {
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .evans-section {
      grid-template-columns: 1fr;
    }

    .evans-label {
      padding: var(--space-lg) 0 0 0;
      display: flex;
      gap: var(--space-md);
    }

    .post-date, .post-author {
      position: static;
    }

    .evans-content {
      border-left: none;
      border-top: 1px solid var(--color-coral);
      padding: var(--space-md) 0 0 0;
    }

    .post-title {
      font-size: 28px;
    }
  }
</style>
