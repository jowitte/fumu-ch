---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'kontakt');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="container content">
    <div class="intro">
      <div class="portrait">
        <img src="/images/jochen-witte.jpg" alt="Jochen Witte" width="240" height="240" />
      </div>
      <div class="intro-text">
        <Content />
      </div>
    </div>

    <div class="contact-options">
      <div class="contact-card">
        <h3>Termin buchen</h3>
        <p>Such dir einen passenden Termin aus — wir melden uns zur vereinbarten Zeit.</p>
        <a href="#" class="btn btn-primary">Termin vereinbaren</a>
      </div>
      <div class="contact-card">
        <h3>LinkedIn</h3>
        <p>Vernetze dich mit uns auf LinkedIn für regelmässige Insights.</p>
        <a href="https://www.linkedin.com/in/jochenwitte/" class="btn btn-accent" target="_blank" rel="noopener">LinkedIn-Profil</a>
      </div>
      <div class="contact-card">
        <h3>E-Mail</h3>
        <p>Konkrete Anfrage? Schreib uns direkt.</p>
        <a href="mailto:jochen@fumu.ch" class="btn btn-primary">jochen@fumu.ch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
    margin: var(--space-lg) 0 var(--space-xl);
  }
  .portrait {
    flex-shrink: 0;
  }
  .portrait img {
    display: block;
    width: 240px;
    height: 240px;
    object-fit: cover;
    border-radius: 2px;
  }
  .intro-text {
    flex: 1;
  }
  .intro-text :global(h2) {
    margin-top: 0;
  }
  @media (max-width: 768px) {
    .intro {
      flex-direction: column;
      gap: var(--space-lg);
    }
  }
  .contact-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }
  .contact-card {
    background: var(--color-neutral);
    padding: var(--space-lg);
    border-radius: 8px;
  }
  .contact-card h3 {
    margin-top: 0;
  }
</style>
