---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockShareBars from "../components/charts/BlockShareBars.astro";
import TrendChart from "../components/charts/TrendChart.astro";
import CollapsibleSection from "../components/CollapsibleSection.astro";
import {
  tracker,
  intro,
  formatDate,
  getCategoryColor,
  describeRunChanges,
  renderInlineLinks,
} from "../data/crawler-tracker";

const description =
  "Welche AI-Crawler lassen gut 100 Sites in der robots.txt zu? Snapshot und Verlauf der fumu-Erhebung – alle 14 Tage, Schwerpunkt Schweiz.";

const categories = [...tracker.by_category].sort(
  (a, b) => b.block_share - a.block_share,
);
const crawlers = [...tracker.by_crawler].sort(
  (a, b) => b.block_share - a.block_share,
);

const categoryItems = categories.map((c) => ({
  label: c.label,
  share: c.block_share,
  detail: `${c.site_count} Sites`,
  color: getCategoryColor(c.category),
}));

const crawlerItems = crawlers.map((c) => ({
  label: c.label,
  share: c.block_share,
  detail: `${c.blocked_sites} von ${tracker.meta.site_count} Sites`,
}));

// Lauf-Log: chronologisch absteigend, die jüngsten 6 offen, Rest klappbar.
const runs = [...(tracker.runs ?? [])].sort((a, b) =>
  b.date.localeCompare(a.date),
);
const OPEN_RUNS = 6;
const recentRuns = runs.slice(0, OPEN_RUNS);
const olderRuns = runs.slice(OPEN_RUNS);

// Site-Liste: nach Kategorie gruppiert, Reihenfolge wie die Kategorie-Balken.
const sites = tracker.sites ?? [];
const siteGroups = categories
  .map((c) => ({
    label: c.label,
    category: c.category,
    sites: sites
      .filter((s) => s.category === c.category)
      .sort((a, b) => a.name.localeCompare(b.name, "de")),
  }))
  .filter((g) => g.sites.length > 0);
// Sites mit Kategorien ausserhalb von by_category nicht still verschlucken.
const knownCategories = new Set(categories.map((c) => c.category));
const otherSites = sites.filter((s) => !knownCategories.has(s.category));
if (otherSites.length > 0) {
  siteGroups.push({
    label: "Weitere",
    category: "other",
    sites: [...otherSites].sort((a, b) => a.name.localeCompare(b.name, "de")),
  });
}

const methodologyDetails = tracker.methodology_details ?? [];

const datasetLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "fumu AI-Crawler-Radar",
  description,
  url: "https://fumu.ch/ai-crawler-radar/",
  inLanguage: "de-CH",
  creator: { "@type": "Organization", name: "fumu", url: "https://fumu.ch" },
  dateModified: tracker.meta.snapshot_date,
  temporalCoverage: `${tracker.trend[0].date}/${tracker.meta.snapshot_date}`,
};
---

<BaseLayout title="AI-Crawler-Radar" description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} />

  <section class="radar-page">
    <div class="container">
      <div class="content">
        <div class="radar-head">
          <div>
            <h1>AI-Crawler-Radar</h1>

            <p class="snapshot-meta">
              Snapshot vom <strong>{formatDate(tracker.meta.snapshot_date)}</strong> ·
              {tracker.meta.site_count} Sites × {tracker.meta.crawler_count} Crawler ·
              Erhebung alle {tracker.meta.cadence_days} Tage
            </p>
          </div>
          <img
            class="radar-head-icon"
            src="/images/icons/ai-crawler-radar.webp"
            alt=""
            loading="lazy"
          />
        </div>

        {
          intro.map((paragraph) => (
            <p class="intro" set:html={renderInlineLinks(paragraph)} />
          ))
        }

        <hr class="section-divider" />

        <h2>Verlauf</h2>
        <p class="section-lead">
          Block-Anteil je Kategorie über die bisherigen Snapshots.
        </p>
        <TrendChart
          trend={tracker.trend}
          categories={categories}
          title="Verlauf des Block-Anteils je Kategorie seit April 2026"
        />

        {
          runs.length > 0 && (
            <section class="run-log">
              <hr class="section-divider" />
              <h2>Aktualisierungen</h2>
              {recentRuns.map((run) => (
                <article class="run">
                  <p class="run-meta">
                    <strong>{formatDate(run.date)}</strong>
                    {describeRunChanges(run) && (
                      <> · {describeRunChanges(run)}</>
                    )}
                  </p>
                  <p
                    class="run-summary"
                    set:html={renderInlineLinks(run.summary)}
                  />
                  {run.commentary && (
                    <p
                      class="run-commentary"
                      set:html={renderInlineLinks(run.commentary)}
                    />
                  )}
                </article>
              ))}
              {olderRuns.length > 0 && (
                <details class="older-runs">
                  <summary>Ältere Läufe ({olderRuns.length})</summary>
                  {olderRuns.map((run) => (
                    <article class="run">
                      <p class="run-meta">
                        <strong>{formatDate(run.date)}</strong>
                        {describeRunChanges(run) && (
                          <> · {describeRunChanges(run)}</>
                        )}
                      </p>
                      <p
                        class="run-summary"
                        set:html={renderInlineLinks(run.summary)}
                      />
                      {run.commentary && (
                        <p
                          class="run-commentary"
                          set:html={renderInlineLinks(run.commentary)}
                        />
                      )}
                    </article>
                  ))}
                </details>
              )}
            </section>
          )
        }

        <div class="details-sections">
          <CollapsibleSection title="Block-Anteil nach Kategorie">
            <p class="section-lead">
              Anteil der Crawler-Site-Paare, die per robots.txt blockiert sind –
              je Site-Kategorie.
            </p>
            <BlockShareBars
              items={categoryItems}
              caption="Block-Anteil nach Site-Kategorie"
            />
          </CollapsibleSection>

          <CollapsibleSection title="Block-Anteil nach Crawler">
            <p class="section-lead">
              Anteil der {tracker.meta.site_count} Sites, die den jeweiligen Crawler
              blockieren.
            </p>
            <BlockShareBars
              items={crawlerItems}
              caption="Block-Anteil nach Crawler"
              monoLabels
            />
          </CollapsibleSection>

          <CollapsibleSection title="Methodik">
            <ul class="methodology-notes">
              {tracker.methodology.map((note) => <li>{note}</li>)}
            </ul>
            {
              methodologyDetails.map((section) => (
                <section>
                  <h3>{section.title}</h3>
                  <p class="methodology-body">{section.body}</p>
                </section>
              ))
            }
          </CollapsibleSection>

          {
            siteGroups.length > 0 && (
              <CollapsibleSection title="Gemonitorte Sites">
                <p class="section-lead">
                  Das volle Sample der Erhebung, gruppiert nach Kategorie.
                </p>
                {siteGroups.map((group) => (
                  <section class="site-group">
                    <h3>
                      {group.label}{" "}
                      <span class="site-count">({group.sites.length})</span>
                    </h3>
                    <ul class="site-list">
                      {group.sites.map((site) => (
                        <li>
                          {site.name}{" "}
                          <span class="site-domain">{site.domain}</span>
                        </li>
                      ))}
                    </ul>
                  </section>
                ))}
              </CollapsibleSection>
            )
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .radar-page {
    padding: var(--space-lg) 0 var(--space-xl) 0;
  }

  .snapshot-meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-light);
    letter-spacing: 0.4px;
    margin-bottom: var(--space-md);
  }

  .radar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .radar-head-icon {
    width: 140px;
    height: 140px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .intro {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  /* Inline-Links aus set:html (renderInlineLinks) – Konvention wie .post-body */
  .intro :global(a),
  .run-summary :global(a),
  .run-commentary :global(a) {
    color: var(--color-coral);
    text-decoration: none;
  }

  .intro :global(a:hover),
  .run-summary :global(a:hover),
  .run-commentary :global(a:hover) {
    text-decoration: underline;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-coral);
    margin: var(--space-lg) 0;
  }

  .section-lead {
    font-size: 14px;
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
  }

  .run {
    margin-bottom: var(--space-lg);
  }

  .run-meta {
    font-size: 13px;
    color: var(--color-text-light);
    letter-spacing: 0.4px;
    margin-bottom: var(--space-xs);
  }

  .run-meta strong {
    color: var(--color-text);
  }

  .run-summary {
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: var(--space-xs);
  }

  .run-commentary {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text-light);
    border-left: 2px solid var(--color-coral);
    padding-left: var(--space-md);
    margin-bottom: 0;
  }

  .older-runs summary {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-light);
    cursor: pointer;
    margin-bottom: var(--space-md);
  }

  .older-runs summary:hover {
    color: var(--color-coral);
  }

  .older-runs summary:focus-visible {
    outline: 2px solid var(--color-coral);
    outline-offset: 4px;
  }

  .details-sections {
    margin-top: var(--space-lg);
  }

  .details-sections :global(.collapsible:last-of-type) {
    border-bottom: 1px solid var(--color-coral);
  }

  .methodology-notes {
    padding-left: 1.25rem;
  }

  .methodology-notes li {
    font-size: 14px;
    color: var(--color-text-light);
    margin-bottom: var(--space-sm);
  }

  .methodology-body {
    font-size: 14px;
    line-height: 1.6;
  }

  .site-group h3 {
    margin-top: var(--space-md);
  }

  .site-count {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-light);
  }

  .site-list {
    list-style: none;
    padding: 0;
    columns: 2;
    column-gap: var(--space-lg);
  }

  .site-list li {
    font-size: 14px;
    margin-bottom: var(--space-xs);
    break-inside: avoid;
  }

  .site-domain {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .site-list {
      columns: 1;
    }

    .radar-head {
      flex-direction: column-reverse;
      align-items: flex-end;
      gap: var(--space-sm);
    }

    .radar-head > div {
      width: 100%;
    }

    .radar-head-icon {
      width: 90px;
      height: 90px;
    }
  }
</style>
