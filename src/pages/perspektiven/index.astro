---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { series as seriesRegistry } from "../../data/series";
import { renderInlineLinks } from "../../data/crawler-tracker";

const posts = (
  await getCollection("perspektiven", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) => {
  return date
    .toLocaleDateString("de-CH", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
    .toUpperCase();
};

const formatMonth = (date: Date) => {
  const s = date.toLocaleDateString("de-CH", {
    year: "numeric",
    month: "long",
  });
  return s.charAt(0).toUpperCase() + s.slice(1);
};

const groupedByMonth: { label: string; posts: typeof posts }[] = [];
for (const post of posts) {
  const label = formatMonth(post.data.date);
  const last = groupedByMonth[groupedByMonth.length - 1];
  if (last && last.label === label) {
    last.posts.push(post);
  } else {
    groupedByMonth.push({ label, posts: [post] });
  }
}

// Serien-Block: Anzahl publizierter Teile pro Serie aus den geladenen Posts.
const seriesList = Object.entries(seriesRegistry).map(([slug, data]) => ({
  slug,
  ...data,
  partCount: posts.filter((p) => p.data.series === slug).length,
}));
---

<BaseLayout
  title="Perspektiven"
  description="Analysen und Einordnungen zu Technologie, Medien und digitaler Werbung."
>
  <section class="evans-page">
    <div class="container">
      <h1>Perspektiven</h1>

      <p class="intro">
        Was sich verändert, warum es wichtig ist und was daraus folgt.
        Einordnungen aus der Praxis, wenn Strategie, Technologie und
        Organisation aufeinandertreffen.
      </p>

      {
        seriesList.map((s) => (
          <aside class="series-callout">
            <span class="callout-label">Serie · {s.partCount} Teile</span>
            <h2 class="callout-title">
              <a href={`/perspektiven/serien/${s.slug}/`}>{s.name}</a>
            </h2>
            <p class="callout-text">{s.teaser}</p>
            {s.callout && (
              <p
                class="callout-text"
                set:html={renderInlineLinks(s.callout.text)}
              />
            )}
          </aside>
        ))
      }

      <hr class="section-divider" />
      {
        posts.length > 0 ? (
          groupedByMonth.map((group) => (
            <div class="evans-section">
              <div class="evans-label">
                <h2>{group.label}</h2>
              </div>
              <div class="evans-content">
                {group.posts.map((post) => (
                  <div class="post-entry">
                    <a href={`/perspektiven/${post.id}/`} class="post-item">
                      <span class="post-date">
                        {formatDate(post.data.date)}
                      </span>
                      <div class="post-body">
                        <h3 class="post-title">{post.data.title}</h3>
                        <p class="post-excerpt">{post.data.description}</p>
                      </div>
                    </a>
                    {post.data.series && seriesRegistry[post.data.series] && (
                      <a
                        href={`/perspektiven/serien/${post.data.series}/`}
                        class="series-tag"
                      >
                        Serie: {seriesRegistry[post.data.series].name}
                      </a>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))
        ) : (
          <div class="evans-section">
            <div class="evans-label">
              <h2>In Kürze</h2>
            </div>
            <div class="evans-content">
              <p>Neue Perspektiven erscheinen in Kürze.</p>
            </div>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    font-family: var(--font-sans);
    font-size: 20px;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 720px;
    margin: 0 0 var(--space-xl) 0;
  }

  .series-callout {
    max-width: 720px;
    background: var(--color-neutral);
    border-left: 3px solid var(--color-coral);
    padding: var(--space-md) var(--space-lg);
    margin: 0 0 var(--space-md) 0;
  }

  .callout-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-coral);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .callout-title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    margin: 0 0 var(--space-xs) 0;
  }

  .callout-title a {
    color: var(--color-coral);
    text-decoration: none;
  }

  .callout-title a:hover {
    text-decoration: underline;
  }

  .callout-text {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  .callout-text + .callout-text {
    margin-top: var(--space-sm);
  }

  .callout-text :global(a) {
    color: var(--color-coral);
    text-decoration: none;
  }

  .callout-text :global(a:hover) {
    text-decoration: underline;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-coral);
    margin: var(--space-xl) 0 0 0;
  }

  .evans-section {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 0;
    margin: var(--space-xl) 0;
  }

  .evans-label {
    padding: 0 var(--space-lg) 0 0;
    display: flex;
    justify-content: flex-end;
  }

  .evans-label h2 {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-coral);
    margin: 0;
    position: sticky;
    top: 80px;
  }

  .evans-content {
    border-left: 1px solid var(--color-coral);
    padding: 0;
  }

  .post-entry {
    padding: var(--space-lg) 0 var(--space-lg) var(--space-lg);
  }

  .post-entry:first-child {
    padding-top: 0;
  }

  .post-entry + .post-entry {
    border-top: 1px solid var(--color-neutral);
  }

  .post-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-md);
    color: inherit;
    text-decoration: none;
  }

  .post-item:hover .post-title {
    color: var(--color-coral);
  }

  .post-item:hover {
    text-decoration: none;
  }

  .series-tag {
    display: inline-block;
    margin-top: var(--space-sm);
    margin-left: calc(120px + var(--space-md));
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
    letter-spacing: 0.3px;
    text-decoration: none;
  }

  .series-tag:hover {
    color: var(--color-coral);
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
    letter-spacing: 0.5px;
    padding-top: 4px;
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    color: var(--color-coral);
    margin: 0 0 var(--space-sm) 0;
    transition: color 0.15s;
  }

  .post-excerpt {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .intro {
      font-size: 18px;
      margin: 0 0 var(--space-lg) 0;
    }

    .evans-section {
      grid-template-columns: 1fr;
    }

    .evans-label {
      padding: var(--space-lg) 0 0 0;
    }

    .evans-label h2 {
      position: static;
    }

    .evans-content {
      border-left: none;
      border-top: 1px solid var(--color-coral);
      padding: var(--space-md) 0 0 0;
    }

    .post-entry {
      padding-left: 0;
    }

    .post-item {
      grid-template-columns: 1fr;
    }

    .series-tag {
      margin-left: 0;
    }
  }
</style>
