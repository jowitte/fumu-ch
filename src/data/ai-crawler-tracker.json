  "runs": [
    {
      "date": "2026-07-13",
      "changes": 10,
      "sites_changed": 2,
      "summary": "[Der Standard](https://derstandard.at/robots.txt) sperrt fünf Scraper- und Trainings-Crawler explizit und öffnet zugleich den OpenAI-Suchbot, dieselbe Trennlinie, die [WSJ](https://wsj.com/robots.txt) und [Reuters](https://reuters.com/robots.txt) im Mai gezogen haben. WSJ nimmt seine Juni-Öffnung teilweise zurück.",
      "commentary": null
    },
    {
      "date": "2026-07-06",
      "changes": 21,
      "sites_changed": 2,
      "summary": "[LinkedIn](https://linkedin.com/robots.txt) stuft den Claude-Suchbot von gesperrt auf teilweise herunter – Zitierbarkeit ja, Trainingsmaterial nein.",
      "commentary": null
    },
    {
      "date": "2026-06-29",
      "changes": 33,
      "sites_changed": 4,
      "summary": "[Heidi.News](https://heidi.news/robots.txt) und [Le Temps](https://letemps.ch/robots.txt) öffnen gezielt für OpenAIs Such- und Assistenz-Bots. [Temu](https://temu.com/robots.txt) pendelt zurück auf selektiv.",
      "commentary": null
    },
    {
      "date": "2026-06-22",
      "changes": 9,
      "sites_changed": 1,
      "summary": "[Temu](https://temu.com/robots.txt) zieht seine selektiven Schranken zurück und steht durchgängig offen – E-Commerce setzt auf Reichweite, nicht auf Content-Schutz.",
      "commentary": null
    },
    {
      "date": "2026-06-15",
      "changes": 1,
      "sites_changed": 1,
      "summary": "[Zeit](https://zeit.de/robots.txt) sperrt Googles Trainings-Crawler – eine einzelne Zelle, gezielte Ergänzung statt Strategiewechsel.",
      "commentary": null
    },
    {
      "date": "2026-06-08",
      "changes": 18,
      "sites_changed": 3,
      "summary": "[Tagesschau](https://tagesschau.de/robots.txt) zieht die komplette AI-Crawler-Sperre zurück – der erste öffentlich-rechtliche Publisher im Sample, der vollständig öffnet. [WSJ](https://wsj.com/robots.txt) weitet seine Allow-Liste aus, [eBay](https://ebay.com/robots.txt) verschärft leicht.",
      "commentary": null
    },
    {
      "date": "2026-06-01",
      "changes": 0,
      "sites_changed": 0,
      "summary": "Erstmals 20 Crawler in der Zeitreihe (u.a. Amazonbot, Mistral, Meta) – die neuen Spalten verdünnen die Block-Quoten optisch, auf dem alten Raster hat sich nichts bewegt.",
      "commentary": null
    },
    {
      "date": "2026-05-25",
      "changes": 20,
      "sites_changed": 3,
      "summary": "[Bloomberg](https://bloomberg.com/robots.txt) geht den Gegenweg zu [WSJ](https://wsj.com/robots.txt) und [Reuters](https://reuters.com/robots.txt) und schliesst die letzten offenen Crawler-Lücken einzeln – die ganze explizite Bot-Reihe steht jetzt auf Sperre. [CNN](https://cnn.com/robots.txt) sperrt Claude-User nach.",
      "commentary": null
    },
    {
      "date": "2026-05-16",
      "changes": 28,
      "sites_changed": 2,
      "summary": "[Reuters](https://reuters.com/robots.txt) folgt dem [WSJ](https://wsj.com/robots.txt)-Muster eine Woche später – Default zu, Ausnahmen für Such- und Zitier-Bots.",
      "commentary": null
    },
    {
      "date": "2026-05-11",
