---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden" description="Die angeforderte Seite existiert nicht.">
  <section class="not-found">
    <div class="container">
      <div class="not-found-layout">
        <div class="not-found-label">
          <span class="error-code">404</span>
        </div>
        <div class="not-found-line"></div>
        <div class="not-found-content">
          <h1>Kein Ergebnis.</h1>
          <p>Die Hypothese war: Diese Seite existiert. Die Daten widerlegen das.</p>
          <a href="/" class="back-link">Zur Startseite</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .not-found-layout {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .error-code {
    font-family: var(--font-sans);
    font-size: 5rem;
    font-weight: 400;
    color: var(--color-coral);
    line-height: 1;
    white-space: nowrap;
  }

  .not-found-line {
    width: 1px;
    align-self: stretch;
    background-color: var(--color-coral);
    flex-shrink: 0;
  }

  .not-found-content h1 {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-text);
    margin: 0 0 var(--space-xs) 0;
  }

  .not-found-content p {
    font-family: var(--font-serif);
    color: var(--color-text-light);
    margin: 0 0 var(--space-lg) 0;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-coral);
    text-decoration: none;
    border-bottom: 1px solid var(--color-coral);
    padding-bottom: 2px;
  }

  .back-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .not-found-layout {
      flex-direction: column;
      text-align: center;
    }

    .not-found-line {
      width: 60px;
      height: 1px;
      align-self: auto;
    }

    .error-code {
      font-size: 3.5rem;
    }
  }
</style>
