---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface ArticleAuthor {
  slug: string;
  name: string;
  linkedin: string;
}

interface Props {
  title: string;
  description?: string;
  article?: {
    title: string;
    description: string;
    date: Date;
    authors?: ArticleAuthor[];
    image?: string;
    slug: string;
  };
}

const { title, description = 'Strategieberatung für Digital Advertising, AdTech/MarTech und AI-Integration', article } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://fumu.ch';

// Breadcrumb aus URL-Pfad ableiten
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: `${siteUrl}/` },
  ...pathSegments.map((seg, i) => ({
    name: seg.charAt(0).toUpperCase() + seg.slice(1).replace(/-/g, ' '),
    url: `${siteUrl}/${pathSegments.slice(0, i + 1).join('/')}/`,
  })),
];

const isHome = pathSegments.length === 0;

// WebSite JSON-LD (nur auf Homepage)
const websiteLd = isHome ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'fumu',
  url: siteUrl,
  description: 'Strategieberatung für Digital Advertising, AdTech/MarTech und AI-Integration im DACH-Raum.',
  inLanguage: 'de-CH',
  publisher: {
    '@type': 'Organization',
    name: 'fumu',
    url: siteUrl,
  },
} : null;

// Organization JSON-LD (auf jeder Seite)
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'fumu',
  url: siteUrl,
  logo: `${siteUrl}/favicon-32x32.png`,
  description: 'Strategieberatung für Digital Advertising, AdTech/MarTech und AI-Integration',
  email: 'hello@fumu.ch',
  foundingDate: '2024',
  founder: {
    '@type': 'Person',
    '@id': `${siteUrl}/#jochen-witte`,
    name: 'Jochen Witte',
    url: 'https://linkedin.com/in/jochenwitte',
    sameAs: ['https://linkedin.com/in/jochenwitte'],
  },
  areaServed: { '@type': 'GeoShape', name: 'DACH' },
  knowsAbout: ['Digital Advertising', 'AdTech', 'MarTech', 'AI Integration', 'Programmatic Advertising'],
};

// BreadcrumbList JSON-LD (auf allen Seiten ausser Home)
const breadcrumbLd = pathSegments.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
} : null;

// Article JSON-LD (nur auf Artikelseiten)
const articleAuthors: ArticleAuthor[] = article?.authors && article.authors.length > 0
  ? article.authors
  : [{ slug: 'jochen-witte', name: 'Jochen Witte', linkedin: 'https://linkedin.com/in/jochenwitte' }];

const articleAuthorLd = articleAuthors.map(a => ({
  '@type': 'Person',
  '@id': `${siteUrl}/#${a.slug}`,
  name: a.name,
  url: a.linkedin,
  sameAs: [a.linkedin],
}));

const articleLd = article ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.description,
  datePublished: article.date.toISOString(),
  author: articleAuthorLd.length === 1 ? articleAuthorLd[0] : articleAuthorLd,
  publisher: {
    '@type': 'Organization',
    name: 'fumu',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/og-default.png`,
      width: 1200,
      height: 630,
    },
  },
  ...(article.image ? { image: `${siteUrl}${article.image}` } : {}),
  mainEntityOfPage: canonicalUrl.toString(),
  url: canonicalUrl.toString(),
} : null;

const ogImage = article?.image ? `${siteUrl}${article.image}` : `${siteUrl}/images/og-default.png`;

const ogType = article ? 'article' : 'website';
---

<!DOCTYPE html>
<html lang="de-CH">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} – fumu</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={`${title} – fumu`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="fumu" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} – fumu`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  {article && <meta property="article:published_time" content={article.date.toISOString().split('T')[0]} />}
  {article && articleAuthors.map(a => <meta property="article:author" content={a.name} />)}
  <link rel="preload" href="/fonts/ibm-plex-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/ibm-plex-serif-400-latin.woff2" as="font" type="font/woff2" crossorigin />
  <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
  {websiteLd && <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />}
  {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
  {articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
