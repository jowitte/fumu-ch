---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { releases } from '../data/updates';

const page = await getEntry('pages', 'home');
const posts = (await getCollection('perspektiven', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Update-Stream: Perspektiven und Releases gemischt, absteigend nach Datum.
const updates = [
  ...posts.map((post) => ({
    date: post.data.date,
    href: `/perspektiven/${post.id}/`,
    title: post.data.title,
    description: post.data.description,
    icon: post.data.icon,
    tag: null as string | null,
  })),
  ...releases.map((r) => ({
    date: new Date(r.date),
    href: r.href,
    title: r.title,
    description: r.description,
    icon: r.icon,
    tag: 'Release' as string | null,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('de-CH', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
};
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <h1 class="hero-title">Technologie in Wirkung übersetzen.</h1>
        <p class="hero-sub">Wir verbinden Strategie, Organisation und Technologie – damit aus technologischem Potenzial echte Wirkung wird.</p>
      </div>
      <img
        class="hero-icon"
        src="/images/icons/hero-wirkung.webp"
        alt=""
        fetchpriority="high"
      />
    </div>
  </section>

  {updates.length > 0 && (
    <section class="recent-posts">
      <div class="container">
        <hr class="section-divider" />
        <div class="posts-grid">
          <div class="posts-label">
            <h2>Updates</h2>
          </div>
          <div class="posts-list">
            {updates.map(update => (
              <a href={update.href} class="post-row">
                <span class="post-date">{formatDate(update.date)}</span>
                <div class="post-text">
                  <span class="post-title">
                    {update.tag && <span class="update-tag">{update.tag}</span>}
                    {update.title}
                  </span>
                  <span class="post-description">{update.description}</span>
                </div>
                {update.icon && (
                  <img class="post-row-icon" src={update.icon} alt="" loading="lazy" />
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 12vh 0 8vh;
  }

  .hero-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .hero-icon {
    width: 280px;
    height: 280px;
    object-fit: contain;
    flex-shrink: 0;
    margin-right: var(--space-xl);
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 400;
    color: var(--color-coral);
    line-height: 1.15;
    margin-top: 0;
    margin-bottom: var(--space-md);
    max-width: 700px;
  }
  .hero-sub {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.5;
    max-width: 600px;
  }

  .recent-posts {
    padding-bottom: 12vh;
  }

  .section-divider {
    border: none;
    border-top: 1px solid var(--color-coral);
    margin: 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 0;
    margin: var(--space-xl) 0;
  }

  .posts-label {
    padding: 0 0 0 0;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-right: var(--space-lg);
  }

  .posts-label h2 {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-coral);
    margin: 0;
    line-height: 17px;
  }

  .posts-list {
    border-left: 1px solid var(--color-coral);
    padding-left: var(--space-lg);
  }

  .post-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    padding: 0 0 var(--space-xl) 0;
    text-decoration: none;
  }

  .post-text {
    flex: 1;
  }

  .post-row-icon {
    width: 72px;
    height: 72px;
    object-fit: contain;
    flex-shrink: 0;
    align-self: center;
  }

  .post-row:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-light);
    letter-spacing: 0.5px;
    flex-shrink: 0;
    width: 100px;
  }

  .post-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--color-coral);
    line-height: 1;
  }

  .update-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-coral);
    padding: 2px 6px;
    border-radius: 2px;
    margin-right: var(--space-sm);
    vertical-align: 2px;
  }

  .post-description {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .hero { padding: 6vh 0 4vh; }
    .hero-title { font-size: 32px; }
    .hero-sub { font-size: 18px; }

    /* Hero stapelt: Text voll breit, Doodle kleiner darunter rechts */
    .hero-grid {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }

    .hero-icon {
      width: 150px;
      height: 150px;
      margin: 0;
      align-self: flex-end;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .posts-label {
      padding: var(--space-lg) 0 0 0;
      justify-content: flex-start;
    }

    .posts-list {
      border-left: none;
      border-top: 1px solid var(--color-coral);
      padding-left: 0;
    }

    /* Zeile als Grid: Datum oben, Text links, kleines Icon rechts */
    .post-row {
      display: grid;
      grid-template-columns: 1fr 64px;
      column-gap: var(--space-md);
      row-gap: var(--space-xs);
      align-items: start;
    }

    .post-date {
      width: auto;
      grid-column: 1 / -1;
    }

    .post-row-icon {
      width: 64px;
      height: 64px;
      align-self: start;
    }
  }
</style>
