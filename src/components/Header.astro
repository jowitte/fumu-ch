---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/was-wir-tun/', label: 'Was wir tun' },
  { href: '/about/', label: 'Über fumu' },
  { href: '/perspektiven/', label: 'Perspektiven' },
  { href: '/kontakt/', label: 'Kontakt' },
];
---

<header class="site-header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="logo">fumu</a>
      <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-list">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const navList = document.querySelector('.nav-list');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    navList?.classList.toggle('open');
  });
</script>

<style>
  .site-header {
    background: var(--color-white);
    border-bottom: 1px solid var(--color-coral);
    padding: var(--space-md) 0;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .logo {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-coral);
    letter-spacing: 0.5px;
  }

  .logo:hover {
    color: var(--color-coral);
    text-decoration: none;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--space-lg);
    padding: 0;
    margin: 0;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.3px;
  }

  .nav-link:hover {
    color: var(--color-coral);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-coral);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }
    .nav-list {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: var(--space-md);
      padding-top: var(--space-md);
    }
    .nav-list.open {
      display: flex;
    }
  }
</style>
