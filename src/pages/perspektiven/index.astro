---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'perspektiven');
const { Content } = await render(page);
const posts = (await getCollection('perspektiven', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="container">
    <h1 class="section-title">{page.data.title}</h1>
    <div class="intro">
      <Content />
    </div>

    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <a href={`/perspektiven/${post.id}/`}>
              <span class="date">
                {post.data.date.toLocaleDateString('de-CH', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p>Neue Perspektiven erscheinen in Kürze.</p>
    )}
  </section>
</BaseLayout>

<style>
  .intro {
    max-width: var(--content-width);
    margin-bottom: var(--space-xl);
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-item {
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-neutral);
  }
  .post-item a {
    color: inherit;
    display: block;
  }
  .post-item a:hover { text-decoration: none; }
  .post-item a:hover .post-title { color: var(--color-coral); }
  .post-title {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 600;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-sm);
    line-height: 1.2;
  }
  .post-excerpt {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--color-text-light);
    margin: 0;
  }
</style>
